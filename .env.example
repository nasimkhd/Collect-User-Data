# Event branding (shown on the form)
EVENT_NAME="Sport Card Expo Toronto"
BOOTH_NAME="Photo Booth"
EVENT_HASHTAG="#SCMEToronto"

# Event start date (YYYY-MM-DD). Used to compute D1/D2/… automatically.
# If today < EVENT_START_DATE, day defaults to 1 (useful for testing).
EVENT_START_DATE="2026-04-30"
EVENT_TOTAL_DAYS=2

# Admin dashboard password (change this!)
ADMIN_PASSWORD="1234"

# Session secret for admin cookie (any random long string)
SESSION_SECRET="replace-with-a-long-random-string-at-least-32-chars"

# Optional: override day manually. Leave blank to auto-compute from EVENT_START_DATE.
# EVENT_DAY_OVERRIDE=1

# ─────────────────────────────────────────────────────────────
#  Email sending (used by `npm run send-emails`)
# ─────────────────────────────────────────────────────────────

# SMTP provider. Works with Resend, SendGrid, Postmark, Mailgun, Gmail, etc.
#
# Resend example (recommended — free 3,000/mo):
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=465
#   SMTP_USER=resend
#   SMTP_PASS=re_YOUR_API_KEY
#
# SendGrid example:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=465
#   SMTP_USER=apikey
#   SMTP_PASS=SG.YOUR_API_KEY
#
# Gmail (personal, low volume, requires App Password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your-16-char-app-password
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=a8f75e001@smtp-brevo.com
SMTP_PASS=JpcC5ZyNDT1da0kb

# Who the email appears to be from. Must be on a domain verified with your provider.
SMTP_FROM="Photo Booth <khodapanah.nasim@gmail.com>"
# SMTP_REPLY_TO=you@yourdomain.com

# Where per-ticket photo folders live. Each guest's photos go into a subfolder
# named exactly like their ticket code (e.g. "D1-047/IMG_1234.jpg"). Can be
# absolute or relative — for Dropbox/Drive sync, use an absolute path like
# /Users/you/Dropbox/BoothPhotos.
PHOTOS_DIR=/Users/breezekhd/Library/CloudStorage/Dropbox/BoothPhotos


# Delivery mode:
#   "attach" = attach photos directly to the email (simplest, <= 20MB)
#   "link"   = include a link to an external gallery (Pixieset, Dropbox, etc.)
PHOTO_DELIVERY_MODE=attach

# Used when PHOTO_DELIVERY_MODE=link. Use {ticket_code} as the placeholder.
# PHOTO_LINK_TEMPLATE=https://gallery.example.com/{ticket_code}

# Max total size of attached photos per email (bytes). Default: 20 MB.
# MAX_ATTACHMENT_BYTES=20971520

# Unsubscribe URL (required by CASL). Use mailto: or a real URL.
UNSUBSCRIBE_URL=mailto:unsubscribe@yourdomain.com
